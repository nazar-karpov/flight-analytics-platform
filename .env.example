# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123

# ─── Airflow ──────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
AIRFLOW_SECRET_KEY=a-very-secret-key-change-me-in-prod

# ─── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ─── OpenRouter (AI Agent) ────────────────────────────────────────────────────
# Get your free API key at https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ─── OpenSky Network (optional, increases rate limits) ────────────────────────
# Register at https://opensky-network.org/
# Without auth: ~5 req/10s.  With auth: ~1 req/sec.
OPENSKY_USER=
OPENSKY_PASS=
